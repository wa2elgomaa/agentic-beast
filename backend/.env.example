# Database Configuration
DATABASE_URL=postgresql+asyncpg://beast:beast@localhost:5432/beast
DATABASE_ECHO=false

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
API_TITLE=Agentic Beast API
API_VERSION=0.1.0

# Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
AUTH_PROVIDER=local  # local or ldap

# LDAP Configuration (if using LDAP)
LDAP_SERVER=ldap://localhost:389
LDAP_BASE_DN=dc=example,dc=com
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=

# Gmail Configuration
GMAIL_CREDENTIALS_PATH=./credentials.json
GMAIL_INBOX_QUERY= 
#has:attachment is:unread
GMAIL_EMAIL_MONITOR_INTERVAL_SECONDS=300

# CMS API Configuration
CMS_API_BASE_URL=http://localhost:3000/api
CMS_API_TIMEOUT=10

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27018/articles_db

# AI Provider Configuration
AI_PROVIDER=openai  # openai or bedrock
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4
OPENAI_SQL_MODEL=gpt-4
OPENAI_INTENT_MODEL=gpt-4
OPENAI_PARSE_MODEL=gpt-4
OPENAI_TAG_MODEL=gpt-4
OPENAI_RECOMMENDATION_MODEL=gpt-4
OPENAI_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# AWS Configuration (if using Bedrock)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Embedding Service Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu  # cpu or cuda

# Document Processing Configuration
DOCUMENT_CHUNK_SIZE=1000
DOCUMENT_CHUNK_OVERLAP=200
DOCUMENT_MAX_FILE_SIZE_MB=50

# Observability Configuration
STRUCTLOG_LEVEL=INFO
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_SAMPLE_RATE=0.1

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CALLS=100
RATE_LIMIT_PERIOD=60

# Watched Folder Configuration
WATCHED_FOLDER_PATH=./watched_documents/

# Application Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO
TIMEZONE=UTC

# ========== Agent Configuration (from config/agent_settings.yaml) ==========

# Agent LLM Timeouts (seconds)
AGENT_ANALYTICS_TIMEOUT_SECONDS=45
AGENT_TAGGING_TIMEOUT_SECONDS=30
AGENT_RECOMMENDATION_TIMEOUT_SECONDS=90
AGENT_INTENT_CLASSIFIER_TIMEOUT_SECONDS=15
AGENT_ROUTER_TIMEOUT_SECONDS=20

# SQL Generation
SQL_GENERATION_MAX_RETRIES=2
SQL_GENERATION_RETRY_MULTIPLIER=1.5

# Tagging Configuration
TAGGING_MAX_TAGS=10
TAGGING_MIN_TAGS=3

# Recommendation Configuration
RECOMMENDATION_MAX_RESULTS=20

# ========== Code Interpreter Settings ==========

CODE_INTERPRETER_TIMEOUT_SECONDS=30
CODE_INTERPRETER_MAX_LINES=30
CODE_INTERPRETER_MAX_LENGTH_CHARS=5000
CODE_INTERPRETER_RESTRICTED_PYTHON_ENABLED=true

# ========== Database Settings ==========

DB_STATEMENT_TIMEOUT_MS=10000
DB_MAX_ROWS_PER_QUERY=200
DB_DEFAULT_LIMIT=20
DB_QUERY_CACHE_TTL_SECONDS=300
ANALYTICS_TOP_N_MAX=20
PUBLISHING_INSIGHTS_DEFAULT_DAYS=90
PUBLISHING_INSIGHTS_MIN_DAYS=7
PUBLISHING_INSIGHTS_MAX_DAYS=365

# ========== Value Guard Settings ==========

VALUE_GUARD_ENABLED=true
VALUE_GUARD_THRESHOLD=100

# ========== Retry Policy ==========

RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_SECONDS=1.0
RETRY_MAX_DELAY_SECONDS=60.0
RETRY_BACKOFF_MULTIPLIER=2.0
RETRY_JITTER_ENABLED=true

# ========== Text Sanitization ==========

TEXT_SANITIZE_MAX_LENGTH_DEFAULT=800
TEXT_SANITIZE_MAX_LENGTH_ERRORS=600
TEXT_SANITIZE_MAX_LENGTH_DESCRIPTIONS=1200
TEXT_SANITIZE_REMOVE_NON_PRINTABLE=true

# ========== API Timeouts ==========

HTTP_CLIENT_TIMEOUT_SECONDS=60.0
EXTERNAL_API_TIMEOUT_SECONDS=30.0

# ========== Follow-up Detection ==========

FOLLOWUP_DETECTION_ENABLED=true
FOLLOWUP_USE_CONVERSATION_CONTEXT=true
FOLLOWUP_CONFIDENCE_THRESHOLD=0.6

# ========== Few-Shot Configuration ==========

FEW_SHOT_DYNAMIC_GENERATION_ENABLED=true
FEW_SHOT_NUM_EXAMPLES_PER_INTENT=3
FEW_SHOT_CACHE_LOCALLY=true
FEW_SHOT_FALLBACK_TO_STORED=true

# ========== Configuration Directories ==========

CONFIG_DIR=config

